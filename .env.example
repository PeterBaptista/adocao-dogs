# Postgres (matches docker-compose.yml)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/adocao

# Better Auth — generate a secret with: openssl rand -hex 32
BETTER_AUTH_SECRET=replace-me
BETTER_AUTH_URL=http://localhost:3000

# Admin account created by `pnpm db:seed` (change before seeding)
ADMIN_EMAIL=admin@adocao.local
ADMIN_PASSWORD=changeme123
